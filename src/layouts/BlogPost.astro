---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import CopyButton from '../components/CopyButton.astro';
import { SITE_TITLE, SITE_URL, SITE_AUTHOR } from '../consts';
import { getReadingTime } from '../utils/reading-time';
import '../styles/global.css';
import { extractHeadings } from '../utils/toc';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string; rawContent?: string };

const { title, description, pubDate, updatedDate, heroImage, slug, rawContent } = Astro.props;

const ogImageUrl = slug ? `/blog/${slug}/og-image.png` : '/og-default.png';

const readingTime = rawContent ? getReadingTime(rawContent) : null;
const headings = rawContent ? extractHeadings(rawContent) : [];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": SITE_AUTHOR
  },
  "publisher": {
    "@type": "Person",
    "name": SITE_AUTHOR
  },
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate || pubDate).toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "id": new URL(Astro.url.pathname, SITE_URL).toString()
  },
  "image": heroImage ? new URL(heroImage.src, SITE_URL).toString() : new URL(ogImageUrl, SITE_URL).toString()
};
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} ogImageUrl={ogImageUrl} article={true} publishedTime={pubDate} modifiedTime={updatedDate} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground">

    <Header />

    <main class="flex-1 flex justify-center">

      <!-- Article content — centered column -->
      <article class="w-full max-w-3xl px-6 md:px-10 py-12 sm:py-16 lg:py-20">

        <!-- Header section -->
        <header class="mb-16 space-y-6">

          <!-- Date & reading time -->
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-mono tabular-nums text-muted">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <span class="hidden sm:inline">·</span>
                <span>Updated <FormattedDate date={updatedDate} /></span>
              </>
            )}
            {readingTime && (
              <>
                <span class="hidden sm:inline">·</span>
                <span>{readingTime}</span>
              </>
            )}
          </div>

          <!-- Title -->
          <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-[3.2rem] leading-[1.15] tracking-tight">
            {title}
          </h1>

          <!-- Description / excerpt -->
          {description && (
            <p class="text-lg text-muted leading-relaxed max-w-2xl italic font-sans">
              {description}
            </p>
          )}

        </header>

        <!-- Hero Image -->
        {heroImage && (
          <figure class="mb-16">
            <Image
              width={1020}
              height={510}
              src={heroImage}
              alt=""
              class="w-full rounded-sm border border-border"
              loading="eager"
            />
          </figure>
        )}

        <!-- Article body — custom typography replacing prose -->
        <div class="content-body">
          <slot />
        </div>

        <!-- End marker -->
        <div class="mt-20 pt-12 border-t border-border flex items-center justify-between">
          <span class="font-sans text-xs uppercase tracking-[0.2em] text-muted">End of article</span>
          <a href="/blog" class="font-mono text-xs tabular-nums text-muted hover:text-accent transition-colors duration-300">Back to blog →</a>
        </div>

      </article>

      <!-- Table of Contents sidebar — desktop only -->
      {headings.length > 1 && (
        <aside class="hidden xl:block fixed right-8 top-24 w-56">
          <TableOfContents headings={headings} />
        </aside>
      )}

    </main>

    <CopyButton />

    <Footer />

  </body>
</html>
