---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import CopyButton from '../components/CopyButton.astro';
import { SITE_TITLE, SITE_URL, SITE_AUTHOR } from '../consts';
import { getReadingTime } from '../utils/reading-time';
import '../styles/global.css';
import { extractHeadings } from '../utils/toc';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string; rawContent?: string };

const { title, description, pubDate, updatedDate, heroImage, slug, rawContent } = Astro.props;

// Fetch all writing posts for related posts
const allPosts = await getCollection('writing');

const ogImageUrl = slug ? `/blog/${slug}/og-image.png` : '/og-default.png';

// Breadcrumbs for structured data
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Writing', href: '/writing' },
  { label: title, href: `/writing/${slug}` }
];

const readingTime = rawContent ? getReadingTime(rawContent) : null;
const headings = rawContent ? extractHeadings(rawContent) : [];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": SITE_AUTHOR
  },
  "publisher": {
    "@type": "Person",
    "name": SITE_AUTHOR
  },
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate || pubDate).toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "id": new URL(Astro.url.pathname, SITE_URL).toString()
  },
  "image": heroImage ? new URL(heroImage, SITE_URL).toString() : new URL(ogImageUrl, SITE_URL).toString()
};
---

<html lang="en">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      image={heroImage} 
      ogImageUrl={ogImageUrl} 
      article={true} 
      publishedTime={pubDate} 
      modifiedTime={updatedDate}
      breadcrumbs={breadcrumbs}
    />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground">

    <Header />

    <main class="flex-1 flex justify-center">

      <!-- Article content — wider column for readability -->
      <article class="w-full max-w-7xl px-6 md:px-10 py-12 sm:py-16 lg:py-20">

        <!-- Header section -->
        <header class="mb-16 space-y-6">

          <!-- Date & reading time -->
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-mono tabular-nums text-muted">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                <span class="hidden sm:inline">·</span>
                <span>Updated <FormattedDate date={updatedDate} /></span>
              </>
            )}
            {readingTime && (
              <>
                <span class="hidden sm:inline">·</span>
                <span>{readingTime}</span>
              </>
            )}
            <span class="hidden sm:inline">·</span>
            <span>by {SITE_AUTHOR}</span>
          </div>

          <!-- Social Sharing -->
          <div class="flex items-center gap-3 pt-2">
            <span class="font-sans text-xs uppercase tracking-[0.15em] text-muted">Share:</span>
            <a 
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(SITE_URL + '/writing/' + slug)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center border-2 border-border hover:border-accent dark:hover:border-accent transition-all duration-300 group"
              aria-label="Share on Twitter/X"
            >
              <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <a 
              href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(SITE_URL + '/writing/' + slug)}&title=${encodeURIComponent(title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center border-2 border-border hover:border-accent dark:hover:border-accent transition-all duration-300 group"
              aria-label="Share on LinkedIn"
            >
              <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          </div>

          <!-- Title -->
          <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-[3.2rem] leading-[1.15] tracking-tight">
            {title}
          </h1>

          <!-- Description / excerpt -->
          {description && (
            <p class="text-lg text-muted leading-relaxed max-w-2xl italic font-sans">
              {description}
            </p>
          )}

        </header>

        <!-- Hero Image -->
        {heroImage && (
          <figure class="mb-16">
            <img
              src={heroImage}
              alt=""
              class="w-full rounded-sm border border-border"
              loading="eager"
            />
          </figure>
        )}

        <!-- Article body — custom typography replacing prose -->
        <div class="content-body">
          <slot />
        </div>

        <!-- Related Posts -->
        <RelatedPosts posts={allPosts} currentSlug={slug} />

        <!-- End marker -->
        <div class="mt-20 pt-12 border-t border-border flex items-center justify-between">
          <span class="font-sans text-xs uppercase tracking-[0.2em] text-muted">End of article</span>
          <a href="/writing" class="font-mono text-xs tabular-nums text-muted hover:text-accent transition-colors duration-300">Back to writing →</a>
        </div>

      </article>

      <!-- Table of Contents sidebar — desktop only -->
      {headings.length > 1 && (
        <aside class="hidden xl:block fixed right-8 top-24 w-56">
          <TableOfContents headings={headings} />
        </aside>
      )}

    </main>

    <CopyButton />

    <Footer />

  </body>
</html>
