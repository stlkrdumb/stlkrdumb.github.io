---

import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_URL } from '../consts';

import '../styles/global.css';
type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, pubDate, updatedDate, heroImage, techStack } = Astro.props;

// Breadcrumbs for structured data
const slug = Astro.url.pathname.split('/').pop() || '';
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Portfolio', href: '/work' },
  { label: title, href: `/work/${slug}` }
];
---

<html lang="en">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      breadcrumbs={breadcrumbs}
    />
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <Header />

    <main class="flex-1 flex flex-col">

      <!-- Page header — minimal -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pt-24 pb-8 sm:pt-32 sm:pb-12">
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-muted block mb-3">{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
          <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl leading-tight tracking-tight mb-4">{title}</h1>
          <p class="text-muted text-lg max-w-2xl leading-relaxed">{description}</p>
          
          <!-- Social Sharing -->
          <div class="flex items-center gap-3 mt-6">
            <span class="font-sans text-xs uppercase tracking-[0.15em] text-muted">Share:</span>
            <a 
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(SITE_URL + '/work/' + slug)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center border-2 border-border hover:border-accent dark:hover:border-accent transition-all duration-300 group"
              aria-label="Share on Twitter/X"
            >
              <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <a 
              href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(SITE_URL + '/work/' + slug)}&title=${encodeURIComponent(title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center border-2 border-border hover:border-accent dark:hover:border-accent transition-all duration-300 group"
              aria-label="Share on LinkedIn"
            >
              <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Tech stack -->
      {techStack && techStack.length > 0 && (
        <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pb-12">
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="font-mono text-[10px] uppercase tracking-widest text-muted px-4 py-2 border border-border">{tech}</span>
            ))}
          </div>
        </section>
      )}

      <!-- Divider -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16">
        <hr class="border-border" />
      </div>

      <!-- Hero image — full width within container -->
      {heroImage && (
        <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 py-16 sm:py-20">
          <figure class="relative overflow-hidden border border-border aspect-[2/1]">
            <img
              src={typeof heroImage === 'string' ? heroImage : (heroImage as any).src}
              alt=""
              width="1200"
              height="600"
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </figure>
        </section>
      )}

      <!-- Divider -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16">
        <hr class="border-border" />
      </div>

      <!-- Article body — editorial typography -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 py-16 sm:py-24">
          <article class="content-body max-w-none">
          <slot />
        </article>
      </section>

      <!-- End marker -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pb-20 sm:pb-32 pt-12 border-t border-border flex items-center justify-between">
        <span class="font-sans text-xs uppercase tracking-[0.2em] text-muted">End of project</span>
        <a href="/portfolio" class="font-mono text-xs tabular-nums text-muted hover:text-accent transition-colors duration-300">Back to portfolio →</a>
      </div>

    </main>

    <Footer />

  </body>
</html>
