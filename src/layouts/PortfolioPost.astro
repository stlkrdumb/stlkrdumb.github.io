---

import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

import '../styles/global.css';
type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, pubDate, updatedDate, heroImage, techStack } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <Header />

    <main class="flex-1 flex flex-col">

      <!-- Page header — minimal -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pt-24 pb-8 sm:pt-32 sm:pb-12">
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-muted block mb-3">{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
          <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl leading-tight tracking-tight mb-4">{title}</h1>
          <p class="text-muted text-lg max-w-2xl leading-relaxed">{description}</p>
        </div>
      </section>

      <!-- Tech stack -->
      {techStack && techStack.length > 0 && (
        <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pb-12">
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="font-mono text-[10px] uppercase tracking-widest text-muted px-4 py-2 border border-border">{tech}</span>
            ))}
          </div>
        </section>
      )}

      <!-- Divider -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16">
        <hr class="border-border" />
      </div>

      <!-- Hero image — full width within container -->
      {heroImage && (
        <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 py-16 sm:py-20">
          <figure class="relative overflow-hidden border border-border aspect-[2/1]">
            <img
              src={typeof heroImage === 'string' ? heroImage : (heroImage as any).src}
              alt=""
              width="1200"
              height="600"
              class="w-full h-full object-cover"
            />
          </figure>
        </section>
      )}

      <!-- Divider -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16">
        <hr class="border-border" />
      </div>

      <!-- Article body — editorial typography -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 py-16 sm:py-24">
          <article class="content-body max-w-none">
          <slot />
        </article>
      </section>

      <!-- End marker -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pb-20 sm:pb-32 pt-12 border-t border-border flex items-center justify-between">
        <span class="font-sans text-xs uppercase tracking-[0.2em] text-muted">End of project</span>
        <a href="/portfolio" class="font-mono text-xs tabular-nums text-muted hover:text-accent transition-colors duration-300">Back to portfolio →</a>
      </div>

    </main>

    <Footer />

  </body>
</html>
