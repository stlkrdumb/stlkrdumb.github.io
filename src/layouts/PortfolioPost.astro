---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, pubDate, updatedDate, heroImage, techStack } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Reading Progress Bar -->
    <div id="reading-progress" class="fixed top-0 left-0 h-1 w-full bg-black dark:bg-white z-50 origin-left scale-x-0 transition-transform duration-75"></div>
    <Header />
    
    <main class="flex-1">
      <article class="max-w-3xl mx-auto px-4 py-12">
        <div class="space-y-8">
          <!-- Header -->
          <header class="space-y-4">
            <div class="flex items-center gap-3 text-sm text-neutral-500 dark:text-neutral-400">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="text-neutral-400">
                  (Updated: <FormattedDate date={updatedDate} />)
                </span>
              )}
            </div>
            <h1 class="text-3xl sm:text-4xl font-medium tracking-tight leading-tight">
              {title}
            </h1>
            <p class="text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed">
              {description}
            </p>
            {techStack && techStack.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-2">
                {techStack.map((tech) => (
                  <span class="px-3 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-800 dark:text-neutral-200 text-sm font-medium rounded-full">
                    {tech}
                  </span>
                ))}
              </div>
            )}
          </header>

          <!-- Hero Image -->
          {heroImage && (
            <div class="overflow-hidden rounded-lg">
              <Image width={1020} height={510} src={heroImage} alt="" class="w-full" />
            </div>
          )}

          <!-- Content -->
          <div class="prose dark:prose-invert prose-lg max-w-none">
            <slot />
          </div>
        </div>
      </article>
    </main>
    
    <Footer />
    
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const progressBar = document.getElementById('reading-progress');
        if (!progressBar) return;

        if (window.readingProgressHandler) {
          window.removeEventListener('scroll', window.readingProgressHandler);
        }
        
        let ticking = false;
        
        const updateProgress = () => {
          const totalHeight = document.body.scrollHeight - window.innerHeight;
          const progress = totalHeight > 0 ? window.scrollY / totalHeight : 0;
          progressBar.style.transform = `scaleX(${progress})`;
          ticking = false;
        };

        window.readingProgressHandler = () => {
          if (!ticking) {
            window.requestAnimationFrame(updateProgress);
            ticking = true;
          }
        };

        window.addEventListener('scroll', window.readingProgressHandler, { passive: true });
        
        // Initial setup
        updateProgress();
      });
    </script>
  </body>
</html>
