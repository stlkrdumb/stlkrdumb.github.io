---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const projects = (await getCollection('portfolio')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-1">
      <div class="max-w-3xl mx-auto px-4 py-12">
        <header class="mb-12">
          <h1 class="text-3xl font-medium tracking-tight mb-4">Portfolio</h1>
          <p class="text-neutral-600 dark:text-neutral-400">
            Selected projects, experiments, and open-source contributions.
          </p>
        </header>
        
        <div class="space-y-12">
          {
            projects.map((project) => (
              <article class="group relative flex flex-col items-start justify-between">
                <a href={`/portfolio/${project.id}/`} class="block w-full">
                  <div class="space-y-3">
                    <div class="flex items-center gap-3 text-sm text-neutral-500 dark:text-neutral-400">
                      <FormattedDate date={project.data.pubDate} />
                    </div>
                    <h2 class="text-xl font-medium group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors">
                      {project.data.title}
                    </h2>
                    <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
                      {project.data.description}
                    </p>
                    {project.data.techStack && project.data.techStack.length > 0 && (
                      <div class="flex flex-wrap gap-2 pt-2">
                        {project.data.techStack.map((tech) => (
                          <span class="px-2.5 py-0.5 bg-neutral-100 dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300 text-xs font-medium rounded-md">
                            {tech}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </main>
    
    <Footer />
  </body>
</html>
