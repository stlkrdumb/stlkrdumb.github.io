---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const projects = (await getCollection('portfolio')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const totalProjects = projects.length;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Portfolio | ${SITE_TITLE}`} description={SITE_DESCRIPTION} ogImageUrl="/og-default.png" />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">

    <Header />

    <main class="flex-1 flex flex-col">

      <!-- Page header -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 pt-24 pb-16 sm:pt-32 sm:pb-24">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.3em] text-accent mb-4 block">{totalProjects} Projects</span>
            <h1 class="font-serif text-6xl md:text-7xl lg:text-8xl tracking-tight leading-none">Work</h1>
          </div>
          <p class="text-muted max-w-md text-sm leading-relaxed sm:pb-2">
            Selected projects spanning blockchain infrastructure, developer tooling, and web applications. Built with intention.
          </p>
        </div>
      </section>

      <!-- Divider -->
      <div class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16">
        <hr class="border-border" />
      </div>

      <!-- Projects gallery — alternating editorial spreads -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 py-16 sm:py-24 space-y-0">
        {projects.map((project, index) => (
          <article
            class={`group relative border-b border-border last:border-b-0 ${index % 2 === 1 ? 'py-16 sm:py-24' : ''}`}
            style={`animation: fade-in-up 0.8s ease-out forwards; animation-delay: ${0.1 + index * 0.1}s; opacity: 0;`}
          >
            <a href={`/portfolio/${project.id}/`} class="block grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-8 lg:gap-16 items-start">

              <!-- Image — left on even, right on odd (swap via order) -->
              <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
                <figure class="relative overflow-hidden border border-border aspect-[16/9] sm:aspect-[2/1] group-hover:border-accent/40 transition-colors duration-500">
                  <img
                    src={project.data.heroImage.src}
                    alt={project.data.title}
                    width="1200"
                    height="675"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out scale-[1.02] group-hover:scale-100"
                  />
                  <div class="absolute inset-0 bg-background/0 group-hover:bg-background/20 transition-colors duration-500" />

                  <!-- Project number overlay -->
                  <span class="absolute top-4 left-4 font-mono text-xs tabular-nums text-white/80">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                </figure>
              </div>

              <!-- Content -->
              <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-accent block mb-4">
                  {project.data.pubDate.toLocaleDateString('en-US', { year: 'numeric' })}
                </span>
                <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl leading-tight mb-6 group-hover:text-accent transition-colors duration-300">
                  {project.data.title}
                </h2>
                <p class="text-muted text-base leading-relaxed max-w-md mb-8">{project.data.description}</p>

                <!-- Tech stack -->
                {project.data.techStack && project.data.techStack.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {project.data.techStack.map((tech) => (
                      <span class="font-mono text-[10px] uppercase tracking-widest text-muted px-3 py-1.5 border border-border">{tech}</span>
                    ))}
                  </div>
                )}

                <!-- View link -->
                <div class="mt-10 flex items-center gap-2">
                  <span class="font-mono text-xs uppercase tracking-[0.15em] text-muted group-hover:text-accent transition-colors duration-300">View project</span>
                  <svg class="w-4 h-4 text-muted group-hover:text-accent transition-colors duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </div>
              </div>

            </a>
          </article>
        ))}
      </section>

    </main>

    <Footer />

  </body>
</html>
