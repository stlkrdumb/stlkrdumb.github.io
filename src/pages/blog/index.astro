---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} ogImageUrl="/og-default.png" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-1">
      <div class="max-w-3xl mx-auto px-4 py-12">
        <header class="mb-12">
          <h1 class="text-3xl font-medium tracking-tight mb-4">Blog</h1>
          <p class="text-neutral-600 dark:text-neutral-400">
            Thoughts, tutorials, and things I've learned.
          </p>
        </header>
        
        <div class="space-y-10">
          {
            posts.map((post) => (
              <article class="group">
                <a href={`/blog/${post.id}/`} class="block">
                  <div class="space-y-3">
                    <div class="flex items-center gap-3 text-sm text-neutral-500 dark:text-neutral-400">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                    <h2 class="text-xl font-medium group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
                      {post.data.description}
                    </p>
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </main>
    
    <Footer />
  </body>
</html>
