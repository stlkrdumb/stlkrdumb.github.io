---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = 'https://byrai.xyz';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title="404 — Page Not Found" description="The page you're looking for doesn't exist. It might have been moved or deleted." />
  </head>
  <body class="bg-background dark:bg-black text-foreground dark:text-white min-h-screen flex flex-col">
    <Header />

    <main class="flex-1 flex items-center justify-center px-4 py-20">
      <div class="max-w-2xl w-full">
        <!-- Window Frame Container -->
        <div class="border-3 border-border dark:border-white bg-surface dark:bg-black p-6 md:p-8">
          <!-- Window Frame Header -->
          <div class="flex items-center justify-between mb-6 pb-4 border-b-2 border-border dark:border-white">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 bg-red-500 border-2 border-border dark:border-white"></div>
              <div class="w-3 h-3 bg-yellow-500 border-2 border-border dark:border-white"></div>
              <div class="w-3 h-3 bg-green-500 border-2 border-border dark:border-white"></div>
            </div>
            <span class="font-mono text-xs text-muted dark:text-muted uppercase tracking-wider">Error 404</span>
          </div>

          <!-- Content -->
          <div class="space-y-6">
            <!-- Big 404 Number -->
            <div class="text-[120px] md:text-[160px] font-sans font-bold text-border dark:text-white leading-none select-none" aria-hidden="true">
              404
            </div>

            <!-- Title -->
            <h1 class="font-sans text-3xl md:text-4xl font-bold text-foreground dark:text-white">
              Page Not Found
            </h1>

            <!-- Description -->
            <p class="font-serif text-lg text-muted dark:text-muted leading-relaxed max-w-lg">
              The page you're looking for doesn't exist. It might have been moved, deleted, or you typed the URL wrong.
            </p>

            <!-- Actions -->
            <div class="flex flex-wrap gap-3 pt-4">
              <a 
                href="/" 
                class="inline-flex items-center gap-2 px-5 py-3 bg-background dark:bg-black border-2 border-border dark:border-white hover:border-accent dark:hover:border-accent transition-all duration-300 font-sans text-sm font-semibold group"
              >
                <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
                Back Home
              </a>

              <a 
                href="/writing" 
                class="inline-flex items-center gap-2 px-5 py-3 bg-background dark:bg-black border-2 border-border dark:border-white hover:border-accent dark:hover:border-accent transition-all duration-300 font-sans text-sm font-semibold group"
              >
                <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
                View Writing
              </a>
            </div>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="grid grid-cols-2 gap-3 mt-6">
          <a 
            href="/writing" 
            class="group flex items-center justify-between px-5 py-4 bg-background dark:bg-black border-2 border-border dark:border-white hover:border-accent dark:hover:border-accent transition-all duration-300 ease-out-quart"
          >
            <span class="font-sans text-sm font-semibold text-foreground dark:text-white group-hover:text-accent dark:group-hover:text-accent transition-colors duration-300">Writing</span>
            <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent group-hover:translate-x-1.5 transition-all duration-300 ease-out-quart" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          <a 
            href="/work" 
            class="group flex items-center justify-between px-5 py-4 bg-background dark:bg-black border-2 border-border dark:border-white hover:border-accent dark:hover:border-accent transition-all duration-300 ease-out-quart"
          >
            <span class="font-sans text-sm font-semibold text-foreground dark:text-white group-hover:text-accent dark:group-hover:text-accent transition-colors duration-300">Projects</span>
            <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent group-hover:translate-x-1.5 transition-all duration-300 ease-out-quart" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
