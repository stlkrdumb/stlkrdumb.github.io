---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} ogImageUrl="/og-default.png" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-1 flex items-center justify-center">
      <!-- Hero Section -->
      <section class="max-w-3xl mx-auto px-4 py-16 text-center">
        <div class="space-y-8">
          <h1 class="text-4xl sm:text-6xl font-medium tracking-tight leading-tight opacity-0 animate-fade-in-up">
            Building things,<br />
            <span class="text-neutral-500 dark:text-neutral-400">writing about the journey</span>
          </h1>
          <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto leading-relaxed opacity-0 animate-fade-in-up [animation-delay:200ms]">
            Welcome to my personal space on the internet. I write about technology, 
            programming, and things I learn along the way.
          </p>
          <div class="pt-4 opacity-0 animate-fade-in-up [animation-delay:400ms]">
            <a 
              href="/blog" 
              class="inline-flex items-center gap-2 px-6 py-3 bg-black text-white dark:bg-white dark:text-black rounded-lg font-medium hover:opacity-80 transition-opacity"
            >
              Read My Posts
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>
    </main>
    
    <Footer />
  </body>
</html>
