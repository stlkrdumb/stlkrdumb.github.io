---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION} 
      ogImageUrl="/og-default.png"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <!-- Skip navigation -->
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-foreground focus:text-background focus:font-mono focus:text-xs focus:uppercase focus:tracking-widest focus:border-2 focus:border-accent">
      Skip to content
    </a>

    <Header />

    <main id="main" class="flex-1 flex flex-col">

      <!-- Hero Section — Bold Typography -->
      <section class="max-w-[1400px] mx-auto w-full px-6 md:px-10 lg:px-16 py-24 flex-1 flex flex-col justify-center">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          
          <!-- Left: Bold Intro -->
          <div>
            <h1 class="font-sans text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold leading-[0.9] tracking-tight mb-6">
              Hello.<br />
              I'm {SITE_AUTHOR}.
            </h1>
            <p class="text-muted text-lg md:text-xl leading-relaxed max-w-lg">
              I build things for the web. This is a collection of projects, writing, and thoughts.
            </p>
          </div>

          <!-- Right: Profile Picture -->
          <div class="hidden lg:block">
            <img
              src="/pfp.png"
              alt={SITE_AUTHOR}
              width="600"
              height="600"
              loading="eager"
              class="w-full max-w-md mx-auto rounded-sm border-2 border-border object-cover aspect-square"
            />
          </div>

        </div>
      </section>

      <!-- Quick Links Grid -->
      <section class="bg-surface py-16">
        <div class="max-w-[1400px] mx-auto px-6 md:px-10 lg:px-16">
          <h2 class="font-serif text-2xl sm:text-3xl tracking-tight mb-8">Quick links</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a 
              href="/writing" 
              class="group flex items-center justify-between px-6 py-4 bg-background dark:bg-black border-2 border-border dark:border-white hover:border-accent dark:hover:border-accent transition-all duration-300 ease-out-quart"
            >
              <span class="font-sans text-sm font-semibold text-foreground dark:text-white group-hover:text-accent dark:group-hover:text-accent transition-colors duration-300">Writing</span>
              <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent group-hover:translate-x-1.5 transition-all duration-300 ease-out-quart" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>

            <a 
              href="/work" 
              class="group flex items-center justify-between px-6 py-4 bg-background dark:bg-black border-2 border-border dark:border-white hover:border-accent dark:hover:border-accent transition-all duration-300 ease-out-quart"
            >
              <span class="font-sans text-sm font-semibold text-foreground dark:text-white group-hover:text-accent dark:group-hover:text-accent transition-colors duration-300">Projects</span>
              <svg class="w-4 h-4 text-muted dark:text-muted group-hover:text-accent dark:group-hover:text-accent group-hover:translate-x-1.5 transition-all duration-300 ease-out-quart" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </section>

    </main>

    <Footer />

  </body>
</html>
