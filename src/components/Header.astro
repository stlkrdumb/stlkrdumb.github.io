---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white text-black dark:bg-black dark:text-white border-b border-neutral-200 dark:border-neutral-800">
  <nav class="max-w-3xl mx-auto px-4 h-16 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="text-lg font-medium tracking-tight hover:opacity-70 transition-opacity">
        {SITE_TITLE}
      </a>
    </div>
    
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2">
        <HeaderLink href="/" aria-label="Home" title="Home">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span class="text-sm font-medium hidden sm:block">Home</span>
        </HeaderLink>
        <HeaderLink href="/blog" aria-label="Blog" title="Blog">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm font-medium hidden sm:block">Blog</span>
        </HeaderLink>
        <HeaderLink href="/portfolio" aria-label="Portfolio" title="Portfolio">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-sm font-medium hidden sm:block">Portfolio</span>
        </HeaderLink>
      </div>
      
      <div class="w-px h-6 bg-neutral-200 dark:bg-neutral-800"></div>
      
      <ThemeToggle />
    </div>
  </nav>
</header>

<div class="h-16"></div>
