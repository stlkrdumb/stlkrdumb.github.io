---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white text-black dark:bg-black dark:text-white border-b border-neutral-200 dark:border-neutral-800">
  <nav class="max-w-3xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-medium tracking-tight hover:opacity-70 transition-opacity">
      {SITE_TITLE}
    </a>
    
    <div class="flex items-center gap-6">
      <div class="hidden sm:flex items-center gap-6 text-sm">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/portfolio">Portfolio</HeaderLink>
      </div>
      
      <div class="flex items-center gap-3">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>

<div class="h-16"></div>
