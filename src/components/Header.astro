---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/work', label: 'Portfolio' },
  { href: '/writing', label: 'Writing' },
];

function isActive(pathname: string, href: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background border-b-3 border-border">
  <nav class="max-w-[1400px] mx-auto h-16 flex items-center justify-between px-6 md:px-10 lg:px-16">
    <!-- Logo — editorial masthead feel -->
    <a href="/" class="flex items-center gap-3 hover:opacity-70 transition-opacity duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-sm" aria-label={SITE_TITLE}>
      <img src="/logo.svg" alt={SITE_TITLE} class="h-10 w-auto" />
    </a>

    <!-- Nav links — centered, sharp, minimal -->
    <div class="flex items-center gap-x-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-4 py-2 font-sans text-xs uppercase tracking-[0.15em] transition-all duration-200 border-3 ${
            isActive(Astro.url.pathname, link.href)
              ? 'bg-foreground text-background border-border'
              : 'bg-transparent text-foreground border-transparent hover:border-border hover:bg-surface'
          } focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-sm`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Actions — search + theme toggle -->
    <div class="flex items-center gap-x-2">
      <!-- Search icon button -->
      <a
        href="/search"
        class="w-10 h-10 flex items-center justify-center text-foreground border-3 border-border hover:bg-surface transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-sm"
        aria-label="Search"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>

      <!-- Theme toggle — minimal icon only -->
      <ThemeToggle />
    </div>
  </nav>
</header>

<div class="h-16" />
