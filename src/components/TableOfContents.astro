---
import type { Heading } from '../utils/toc';

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

if (!headings || headings.length === 0) {
  return null;
}
---

<nav class="toc hidden xl:block sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto bg-surface dark:bg-black border-3 border-border" style="scrollbar-width: thin; scrollbar-color: #666 #f5f5f5;">
  <style>
    .toc::-webkit-scrollbar {
      width: 8px;
    }
    .toc::-webkit-scrollbar-track {
      background: #f5f5f5;
      border-radius: 0;
    }
    .toc::-webkit-scrollbar-thumb {
      background: #666;
      border: 2px solid #f5f5f5;
      border-radius: 0;
    }
    .toc::-webkit-scrollbar-thumb:hover {
      background: #000;
    }
    
    @media (prefers-color-scheme: dark) {
      .toc::-webkit-scrollbar-track {
        background: #1a1a1a;
      }
      .toc::-webkit-scrollbar-thumb {
        background: #888;
        border-color: #1a1a1a;
      }
      .toc::-webkit-scrollbar-thumb:hover {
        background: #fff;
      }
    }
  </style>
  <!-- Window Frame Header -->
  <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b-2 border-border">
    <div class="flex items-center gap-2">
      <div class="w-2.5 h-2.5 bg-red-500 border-2 border-border"></div>
      <div class="w-2.5 h-2.5 bg-yellow-500 border-2 border-border"></div>
      <div class="w-2.5 h-2.5 bg-green-500 border-2 border-border"></div>
    </div>
    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted">On this page</span>
  </div>
  
  <div class="p-6">
    <ul class="space-y-3">
      {headings.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${heading.slug}`}
            class="block py-1 text-sm leading-snug transition-all duration-200 border-l pl-4 -ml-[1px]"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <script>
    function updateActiveHeading() {
      const headingEls = document.querySelectorAll('h2[id], h3[id]');
      const tocLinks = document.querySelectorAll('.toc a');

      let currentHeading: HTMLElement | null = null;

      // Find the most recent heading that's above the threshold
      headingEls.forEach((heading) => {
        const rect = heading.getBoundingClientRect();
        if (rect.top <= 150) {
          currentHeading = heading as HTMLElement;
        }
      });

      tocLinks.forEach((link) => {
        const href = link.getAttribute('href');
        if (href && currentHeading && href === `#${currentHeading.id}`) {
          link.classList.add('text-accent', 'border-accent');
          link.classList.remove('text-muted', 'dark:text-muted', 'border-transparent');
        } else {
          link.classList.remove('text-accent', 'border-accent');
          link.classList.add('text-muted', 'dark:text-muted', 'border-transparent');
        }
      });
    }

    document.addEventListener('astro:page-load', () => {
      updateActiveHeading();
      window.addEventListener('scroll', updateActiveHeading, { passive: true });
    });
  </script>
</nav>
